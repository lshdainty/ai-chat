# dependencies (node_modules는 내부망 배포를 위해 포함)
# node_modules 내 불필요한 캐시/임시 파일만 제외
node_modules/.vite/
node_modules/.vite-temp/
node_modules/.cache/
**/node_modules/.bin/
node_modules/fsevents/

# build (루트 dist만 제외, node_modules 내 dist는 포함)
/dist/

# env (루트만)
/.env
/.env.local
/.env.*.local

# editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# logs
*.log
npm-debug.log*

# misc
.claude/

# =============================================
# AI Chat 환경변수 설정
# =============================================
# .env 파일에 복사하여 사용하세요.

# 채팅 모드 설정
# - (비어있음) : Mock 모드 (API 연결 없이 목업 응답)
# - api        : Lambda Function URL 또는 API Gateway 엔드포인트 호출
# - arn        : AWS Lambda ARN 직접 호출 (개발/테스트 전용)
VITE_CHAT_MODE=

# === API 모드 설정 (VITE_CHAT_MODE=api) ===
# Lambda Function URL 또는 API Gateway 엔드포인트
VITE_API_URL=

# === ARN 모드 설정 (VITE_CHAT_MODE=arn) ===
# Lambda 함수 ARN
VITE_LAMBDA_ARN=

# AWS 리전 (기본: ap-northeast-2)
VITE_AWS_REGION=ap-northeast-2

# AWS 프로필명 (기본: default, ~/.aws/credentials 기반)
VITE_AWS_PROFILE=default
